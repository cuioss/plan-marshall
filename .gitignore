/.idea/
.qodo
**/**.iml
**/**.DS_Store

# Eclipse IDE files
**/.project
**/.classpath
**/.settings/

# Build output (covers per-target generator output: target/claude/, target/opencode/, …)
target/

# Future per-target output trees alongside target/ (forward-looking)
.cursor-plugin/
.codex-plugin/

# Python cache
**/__pycache__/
*.pyc

# Claude Code configuration
# Claude Code files
.claude/*

# But allow project skills, commands, and run configuration to be shared
!.claude/skills/
!.claude/commands/
!.claude/run-configuration.json

# Ignore user-specific settings
.claude/settings.local.json

# Ignore lessons-learned (runtime knowledge, project-specific)
.claude/lessons-learned/*.md

# Workflow artifacts (plans, lessons, memory, run-config)
# Use .plan/* instead of .plan/ to allow exceptions below
# Planning system (managed by /marshall-steward)
# Runtime state (plans, run-configuration, lessons-learned, memory, logs — managed by plan-marshall)
.plan/*
!.plan/marshal.json
!.plan/project-architecture/



# Pyprojectx (tool installations, downloaded on demand)
.pyprojectx/

# Virtual environment (if using uv directly)
.venv/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Gradle build cache (created by build-gradle fixture tests under test/)
**/.gradle/

# Coverage reports
htmlcov/
.coverage
*.whl
