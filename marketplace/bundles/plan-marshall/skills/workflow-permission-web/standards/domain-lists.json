  "red_flags": [
    {"pattern": "free.*download", "description": "Free download sites — common malware distribution vector"},
    {"pattern": "\\bcrack\\b", "description": "Software cracking — piracy and malware"},
    {"pattern": "\\bkeygen\\b", "description": "Key generators — piracy and malware"},
    {"pattern": "\\btorrent\\b", "description": "Torrent sites — piracy risk"},
    {"pattern": "\\bphish", "description": "Phishing indicators"},
    {"pattern": "\\bmalware\\b", "description": "Explicit malware reference"},
    {"pattern": "\\.tk$", "description": "High-risk free TLD — frequently used for spam/phishing"},
    {"pattern": "\\.ml$", "description": "High-risk free TLD — frequently used for spam/phishing"},
    {"pattern": "\\.ga$", "description": "High-risk free TLD — frequently used for spam/phishing"},
    {"pattern": "\\.cf$", "description": "High-risk free TLD — frequently used for spam/phishing"},
    {"pattern": "\\.gq$", "description": "High-risk free TLD — frequently used for spam/phishing"},
    {"pattern": "\\d{5,}", "description": "5+ consecutive digits — auto-generated or disposable domains"},
    {"pattern": "^login-", "description": "Credential-harvesting prefix pattern"},
    {"pattern": "^signin-", "description": "Credential-harvesting prefix pattern"},
    {"pattern": "^account-", "description": "Credential-harvesting prefix pattern"},
    {"pattern": "-verify\\.", "description": "Verification scam pattern (e.g., paypal-verify.com)"},
    {"pattern": "^secure-.*\\.", "description": "Fake security/update prefix pattern"},
    {"pattern": "^update-.*\\.", "description": "Fake security/update prefix pattern"}
  ]
}
