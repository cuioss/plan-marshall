def _is_build_class_notation(notation: str) -> bool:
    """Return True when ``notation`` belongs to a build-class skill.

    The test is a prefix match on the ``bundle:skill`` segment against
    :data:`_BUILD_CLASS_PREFIXES`, so every script registered under a
    ``build-*`` skill is treated as a build-class dispatch.

    Args:
        notation: Script notation (``bundle:skill:script``).

    Returns:
        True when the notation starts with any build-class prefix.
    """
    return any(notation.startswith(prefix) for prefix in _BUILD_CLASS_PREFIXES)


def _append_build_ledger_record(
    notation: str,
    plan_id: str | None,
    script_args: list[str],
    exit_code: int,
    log_file: str | None,
) -> None:
    """Append one ``kind=build`` change-ledger entry for a build-class dispatch.

    Fired from :func:`main` after the subprocess completes (regardless of
    ``exit_code`` — the freshness gate filters on it). Computes the
    working-tree currency hash via the shared :func:`compute_worktree_sha`
    against the executor's cwd (pinned to the worktree in phase-5, the main
    checkout otherwise), builds the record via :func:`build_record` (which
    stamps ``kind: "build"`` and the ISO timestamp), and appends it via the
    pure-append :func:`append_entry` (which resolves the ledger path under the
    tracked-config ``work/`` dir).

    Fire-and-forget: the whole body is wrapped in a broad ``try/except`` that
    returns silently. A ledger-write failure never alters the dispatched
    script's exit code, stdout, or stderr.

    Args:
        notation: The build-class notation that was dispatched.
        plan_id: Resolved plan id (``None`` for an orchestrator global-tier build).
        script_args: Arguments forwarded to the dispatched script. Joined into
            the free-form ``args`` field.
        exit_code: The build exit code (recorded even when non-zero).
        log_file: The script-execution log path for this dispatch.
    """
    try:
        worktree_sha = compute_worktree_sha(os.getcwd())
        record = build_record(
            notation=notation,
            plan_id=plan_id,
            args=' '.join(script_args) if script_args else None,
            exit_code=exit_code,
            worktree_sha=worktree_sha,
            log_file=log_file,
        )
        append_entry(record)
    except Exception:
        # Fire-and-forget — never propagate failures from the ledger boundary.
        return


def _classify_dispatch_failure(exit_code: int) -> str:
    """
    Classify a non-zero dispatch exit code into a failure kind.

    Python's argparse exits with code 2 on parse failure (unrecognized args,
    missing required args, type-coercion failures, etc.). Distinguishing this
    from a script-internal failure (uncaught exception, explicit sys.exit(1),
    business-logic failure) gives consumers of work.log a structural signal
    they can grep for without parsing stderr.

    Args:
        exit_code: Non-zero process exit code.

    Returns:
        ``argparse_rejection`` when exit_code == 2, ``script_internal_failure``
        for any other non-zero value.
    """
    if exit_code == 2:
        return 'argparse_rejection'
    return 'script_internal_failure'


def _derive_failure_detail(stdout: str, stderr: str) -> str:
    """
    Derive the single-line diagnostic detail for a failed dispatch.

    plan-marshall scripts report structured errors on **stdout** as a
    ``status: error`` TOON payload while exiting non-zero with empty stderr, so
    surfacing only stderr leaves the work.log entry blank and undiagnosable.
    This helper implements option-A precedence — always prefer the reason the
    script itself reported on stdout, falling back to stderr only as a last
    resort:

    1. ``stdout`` parses as a ``status: error`` TOON payload carrying a
       non-empty ``message`` field → return that ``message``.
    2. else ``stdout`` is non-empty → return the raw ``stdout``.
    3. else ``stderr`` is non-empty → return the raw ``stderr`` (last resort,
       covers genuine stderr-only crashes).

    The chosen text is truncated to :data:`_DISPATCH_FAILURE_DETAIL_LIMIT`
    characters and has its newlines collapsed so the work.log entry stays
    single-line.

    Args:
        stdout: Captured stdout from the failed dispatch.
        stderr: Captured stderr from the failed dispatch.

    Returns:
        The single-line, truncated diagnostic detail. Empty string only when
        both stdout and stderr are empty.
    """
    stdout_clean = (stdout or '').strip()
    stderr_clean = (stderr or '').strip()

    detail = ''
    if stdout_clean:
        # Precedence (1): try to parse stdout as a status: error TOON payload
        # and surface its message field. Guarded so non-TOON stdout falls
        # through to precedence (2).
        try:
            parsed = parse_toon(stdout_clean)
            if (
                parsed.get('status') == 'error'
                and parsed.get('message')
            ):
                detail = str(parsed['message']).strip()
        except Exception:
            detail = ''
        # Precedence (2): non-empty unstructured stdout.
        if not detail:
            detail = stdout_clean
    elif stderr_clean:
        # Precedence (3): stderr last resort.
        detail = stderr_clean

    if len(detail) > _DISPATCH_FAILURE_DETAIL_LIMIT:
        detail = detail[:_DISPATCH_FAILURE_DETAIL_LIMIT] + '...[truncated]'
    # Collapse newlines so the work.log entry stays single-line.
    detail = detail.replace('\n', ' \\n ').replace('\r', '')

    return detail


def emit_dispatch_failure_work_log(
    notation: str,
    exit_code: int,
    stdout: str,
    stderr: str,
    script_args: list[str],
    audit_plan_id: str | None,
) -> None:
    """
    Emit a [ERROR] entry to the plan's work.log when a dispatched script
    exits non-zero.

    Three guard rails keep the boundary cheap and recursion-free:

    1. Successful dispatches (exit_code == 0) are skipped at the call site —
       this function assumes the caller already filtered them out.
    2. ``manage-logging`` dispatches are skipped via
       ``_DISPATCH_FAILURE_SUPPRESS_NOTATIONS``. A failure inside
       manage-logging that tried to log itself would re-invoke the executor
       and recurse forever.
    3. work.log is plan-scoped: we need a ``--plan-id`` to know which plan's
       work.log to append to. When neither the dispatched script's own
       arguments nor the executor's ``--audit-plan-id`` flag carry a plan id,
       the entry is dropped silently (the script-execution.log entry from
       :func:`log_script_execution` still records the failure globally).

    The emission itself is wrapped in a broad ``try/except`` so logging
    failures never crash the executor — the dispatched script's exit code is
    the user-visible contract, work.log is best-effort observability.

    The emitted ``detail=`` field carries the reason the script itself
    reported, derived via :func:`_derive_failure_detail` with option-A
    precedence: a ``status: error`` TOON ``message`` on stdout, else non-empty
    raw stdout, else stderr as a last resort. This ensures a non-zero exit that
    reports its error on stdout (the common plan-marshall case) is never again
    surfaced as a blank diagnostic.

    Args:
        notation: Failing script notation (``bundle:skill:script``).
        exit_code: Non-zero exit code observed at the subprocess boundary.
        stdout: Captured stdout from the failed dispatch. Preferred source of
            the ``detail`` field (see :func:`_derive_failure_detail`).
        stderr: Captured stderr from the failed dispatch. Last-resort source of
            the ``detail`` field. The chosen text is truncated to
            :data:`_DISPATCH_FAILURE_DETAIL_LIMIT` characters before emission.
        script_args: Arguments forwarded to the dispatched script (after
            ``--audit-plan-id`` extraction). Searched for ``--plan-id``.
        audit_plan_id: Value of the executor's own ``--audit-plan-id`` flag
            (or ``None`` when absent). Used as fallback when ``script_args``
            does not carry a ``--plan-id``.
    """
    if notation in _DISPATCH_FAILURE_SUPPRESS_NOTATIONS:
        return

    try:
        plan_id = extract_plan_id(script_args) or audit_plan_id
        if not plan_id:
            return

        failure_kind = _classify_dispatch_failure(exit_code)
        detail = _derive_failure_detail(stdout, stderr)

        message = (
            f'[ERROR] (plan-marshall:execute-script:{exit_code}) script_failure '
            f'notation={notation} exit_code={exit_code} failure_kind={failure_kind} '
            f'detail={detail}'
        )
        log_entry('work', plan_id, 'ERROR', message)
    except Exception:
        # Logging is best-effort — never propagate failures from the boundary.
        pass


def should_skip_logging(notation: str, exit_code: int) -> bool:
    """
    Determine if logging should be skipped for this execution.

    Logging scripts (like manage-logging) are not logged when successful to avoid
    meta-logging noise. Errors are always logged regardless of script type.

    Args:
        notation: Script notation (e.g., 'plan-marshall:manage-logging:manage-logging')
        exit_code: Script exit code (0 = success)

    Returns:
        True if logging should be skipped, False otherwise
    """
    return notation in SILENT_ON_SUCCESS and exit_code == 0


def extract_audit_plan_id(args: list[str]) -> tuple[str | None, list[str]]:
    """
    Extract --audit-plan-id from args and return cleaned args.

    --audit-plan-id is audit-only: it routes the executor's own log entry to the
    plan-specific log file and is stripped before passing args to the script.
    The flag never alters the script's behavior — use it for scripts that do not
    accept --plan-id themselves.

    Args:
        args: Command line arguments

    Returns:
        Tuple of (audit_plan_id or None, cleaned_args without --audit-plan-id)
    """
    audit_plan_id = None
    cleaned = []
    skip_next = False

    for i, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue
        if arg == '--audit-plan-id':
            if i + 1 < len(args):
                audit_plan_id = args[i + 1]
                skip_next = True
        elif arg.startswith('--audit-plan-id='):
            audit_plan_id = arg.split('=', 1)[1]
        else:
            cleaned.append(arg)

    return audit_plan_id, cleaned


def _resolve_notation_by_cwd_walk(notation: str) -> str | None:
    """Resolve notation by walking up to a ``marketplace/bundles`` tree.

    Self-heal path for the dev-checkout case: when the embedded SCRIPTS path
    is stale/relocated and the target-aware (plugin-cache / OpenCode) resolver
    finds nothing, walk upward from two anchors looking for a live
    ``marketplace/bundles/{bundle}/skills/{skill}/scripts/{script}.py``:

    1. Each ancestor of ``Path.cwd()`` (covers an executor invoked from inside
       a checkout / worktree where cwd sits under the repo root).
    2. Each ancestor of this executor file's own location (covers an executor
       whose cwd is elsewhere but which itself lives under the checkout).

    The first existing match is returned as an absolute path; ``None`` when no
    anchor yields a live file. No glob, no env var — a pure upward directory
    walk so a relocated checkout resolves without a regeneration or a
    hand-pinned ``PM_MARKETPLACE_ROOT``.
    """
    parts = notation.split(':')
    if len(parts) != 3:
        return None
    bundle, skill, script = parts
    rel = Path('marketplace') / 'bundles' / bundle / 'skills' / skill / 'scripts' / f'{script}.py'

    anchors: list[Path] = []
    try:
        anchors.append(Path.cwd())
    except (OSError, ValueError):
        pass
    try:
        anchors.append(Path(__file__).resolve())
    except (OSError, ValueError, NameError):
        pass

    seen: set[str] = set()
    for anchor in anchors:
        for parent in [anchor, *anchor.parents]:
            key = str(parent)
            if key in seen:
                continue
            seen.add(key)
            try:
                candidate = parent / rel
                if candidate.is_file():
                    return str(candidate.resolve())
            except (OSError, ValueError):
                continue
    return None


def resolve_notation(notation: str) -> str | None:
    """Resolve notation to absolute script path.

    Resolution order:
    1. Direct lookup in SCRIPTS (embedded at generation time) — returned ONLY
       when the embedded path still exists on disk. A stale/relocated embedded
       path is skipped so resolution self-heals via the dynamic fallbacks
       instead of returning a dead path (which previously forced operators to
       hand-pin PM_MARKETPLACE_ROOT on every call).
    2. Prefix/substring fallback in SCRIPTS (compatibility shim) — same
       existence guard applies.
    3. Target-aware dynamic resolver (_resolve_notation_by_target) —
       returns an absolute path discovered from the target-specific skill
       discovery roots (Claude plugin cache or OpenCode config roots).
    4. cwd/executor-file upward walk to a live ``marketplace/bundles`` tree
       (_resolve_notation_by_cwd_walk) — covers the dev-checkout case where the
       target-aware roots are absent.
    """
    # 1. Direct lookup — only honour the embedded path when it still exists.
    if notation in SCRIPTS:
        direct = SCRIPTS[notation]
        if Path(direct).is_file():
            return direct

    # 2. Prefix/substring compatibility shim — same existence guard.
    for key, path in SCRIPTS.items():
        if key.startswith(notation) or notation in key:
            if Path(path).is_file():
                return path

    # 3. Target-aware dynamic fallback (plugin-cache / OpenCode roots).
    resolved = _resolve_notation_by_target(notation)
    if resolved:
        return resolved

    # 4. cwd / executor-file upward walk to a live marketplace/bundles tree.
    return _resolve_notation_by_cwd_walk(notation)


def build_notation_error(notation: str) -> tuple[str, list[str]]:
    """
    Build helpful error message for invalid notation.

    Returns:
        Tuple of (error_message, suggestions)
    """
    suggestions = [key for key in sorted(SCRIPTS.keys()) if notation.lower() in key.lower()]

    # Check if this looks like a subcommand was used as script name
    parts = notation.split(':')
    if len(parts) == 3:
        prefix = f"{parts[0]}:{parts[1]}"
        possible_cmd = parts[2]
        matching_scripts = [k for k in SCRIPTS.keys() if k.startswith(prefix + ':')]
        if matching_scripts:
            correct_script = matching_scripts[0].split(':')[2]
            error_msg = (
                f"Invalid notation: '{notation}'\n"
                f"  The third part '{possible_cmd}' appears to be a subcommand, not a script name.\n"
                f"  Correct format: {prefix}:{correct_script} {possible_cmd}"
            )
            return error_msg, suggestions

    return f"Unknown notation: {notation}", suggestions


def handle_invalid_notation(notation: str, remaining_args: list[str]) -> None:
    """Handle invalid notation lookup with logging and helpful error output."""
    error_msg, suggestions = build_notation_error(notation)

    # Log the invalid lookup
    log_script_execution(
        notation=notation,
        subcommand='',
        args=remaining_args,
        exit_code=1,
        duration=0.0,
        stdout='',
        stderr=error_msg
    )

    print(f"SCRIPT_ERROR\t{notation}\t1\tUnknown notation", file=sys.stderr)
    print(f"\n{error_msg}", file=sys.stderr)
    if suggestions:
        print(f"\nAvailable scripts matching '{notation}':", file=sys.stderr)
        for key in suggestions:
            print(f"  {key}", file=sys.stderr)
    sys.exit(1)


def main():
    if len(sys.argv) < 2:
        print("Usage: execute-script.py <notation> [subcommand] [args...]", file=sys.stderr)
        print("\nNotation format: {bundle}:{skill}:{script}", file=sys.stderr)
        print("\nAvailable scripts:", file=sys.stderr)
        for notation in sorted(SCRIPTS.keys()):
            print(f"  {notation}", file=sys.stderr)
        sys.exit(1)

    notation = sys.argv[1]

    # Handle --list option
    if notation == '--list':
        for n in sorted(SCRIPTS.keys()):
            print(n)
        sys.exit(0)

    remaining_args = sys.argv[2:]

    # Extract --audit-plan-id (audit logging only, stripped before passing to script)
    audit_plan_id, script_args = extract_audit_plan_id(remaining_args)

    # Strip empty string args (defensive: agents may pass empty args from shell variable expansion)
    script_args = [a for a in script_args if a]

    # Subcommand is first arg after stripping audit-plan-id
    subcommand = script_args[0] if script_args else ''

    # Resolve the plan_id for the build-class change-ledger boundary below
    # (script-arg --plan-id or executor --audit-plan-id; may be None for an
    # orchestrator global-tier build). The executor no longer writes any
    # session->plan binding — that policy now lives in platform-runtime's
    # `session bind`, fired from the manage-status phase-state-write drive seam.
    _active_plan_id = extract_plan_id(script_args) or audit_plan_id

    script_path = resolve_notation(notation)
    if not script_path:
        handle_invalid_notation(notation, remaining_args)

    if not Path(script_path).exists():
        print(f"SCRIPT_ERROR\t{notation}\t1\tScript not found: {script_path}", file=sys.stderr)
        sys.exit(1)

    # Execute the script (with cleaned args, no --audit-plan-id)
    start = time.time()
    stdout_capture = ''
    stderr_capture = ''

    # Build environment with PYTHONPATH for cross-skill imports
    env = os.environ.copy()
    existing_pythonpath = env.get('PYTHONPATH', '')
    env['PYTHONPATH'] = _PYTHONPATH + (':' + existing_pythonpath if existing_pythonpath else '')
    # Export PLAN_DIR_NAME so scripts can use it for path construction
    # Use setdefault to respect existing value (e.g., set by test infrastructure)
    env.setdefault('PLAN_DIR_NAME', PLAN_DIR_NAME)

    # Suppress ANSI color in every fronted subprocess so downstream text
    # parsers receive plain output. Python 3.14's argparse --help colorizes
    # when can_colorize() allows it (consulting PYTHON_COLORS, then NO_COLOR,
    # then FORCE_COLOR); colored escapes corrupt option-flag parsers such as
    # plugin-doctor's manage-invocation analyzer. NO_COLOR overrides
    # FORCE_COLOR and PYTHON_COLORS=0 is the explicit override; popping
    # FORCE_COLOR is belt-and-suspenders. CLICOLOR/CLICOLOR_FORCE/PY_COLORS
    # pin the broader CLI surface (git/mvn/gradle/npm/pytest).
    env['PYTHON_COLORS'] = '0'
    env['NO_COLOR'] = '1'
    env.pop('FORCE_COLOR', None)
    env['CLICOLOR'] = '0'
    env['CLICOLOR_FORCE'] = '0'
    env['PY_COLORS'] = '0'

    try:
        # Capture output for logging (but still stream to console)
        result = subprocess.run(
            ['python3', script_path] + script_args,
            capture_output=True,
            text=True,
            env=env
        )
        exit_code = result.returncode
        stdout_capture = result.stdout
        stderr_capture = result.stderr

        # Stream output to console
        if result.stdout:
            print(result.stdout, end='')
        if result.stderr:
            print(result.stderr, end='', file=sys.stderr)

    except Exception as e:
        print(f"SCRIPT_ERROR\t{notation}\t1\t{str(e)}", file=sys.stderr)
        stderr_capture = str(e)
        exit_code = 1

    duration = time.time() - start

    # Build args for logging: inject --plan-id if audit_plan_id was provided
    # This allows log_script_execution to route to plan-specific log
    args_for_logging = script_args.copy()
    if audit_plan_id:
        args_for_logging = ['--plan-id', audit_plan_id] + args_for_logging

    # Log execution (skip for logging scripts on success to avoid meta-logging noise)
    if not should_skip_logging(notation, exit_code):
        log_script_execution(
            notation=notation,
            subcommand=subcommand,
            args=args_for_logging,
            exit_code=exit_code,
            duration=duration,
            stdout=stdout_capture if exit_code != 0 else '',
            stderr=stderr_capture if exit_code != 0 else ''
        )

    # Dispatch-boundary guard: every non-zero exit lands a single [ERROR] line
    # in the plan's work.log so caller-name drift, argparse rejections, and
    # script-internal failures stay visible without grepping
    # script-execution.log. See emit_dispatch_failure_work_log for the
    # recursion guard and the plan-id fallback chain.
    if exit_code != 0:
        emit_dispatch_failure_work_log(
            notation=notation,
            exit_code=exit_code,
            stdout=stdout_capture,
            stderr=stderr_capture,
            script_args=script_args,
            audit_plan_id=audit_plan_id,
        )

    # Build-class dispatch boundary: after every build-class invocation, append
    # a kind=build entry to the unified change-ledger so the freshness gate can
    # ask "was this exact working-tree state built?". Records are appended
    # unconditionally on completion regardless of exit_code (the gate filters on
    # it). The plan_id resolves to the same value used elsewhere in the boundary
    # (script-arg --plan-id or executor --audit-plan-id), and may be None for an
    # orchestrator global-tier build. The writer is fire-and-forget — see
    # _append_build_ledger_record.
    if _is_build_class_notation(notation):
        _append_build_ledger_record(
            notation=notation,
            plan_id=_active_plan_id,
            script_args=script_args,
            exit_code=exit_code,
            log_file=str(get_log_path(_active_plan_id, 'script')),
        )

    sys.exit(exit_code)

if __name__ == '__main__':
    main()
