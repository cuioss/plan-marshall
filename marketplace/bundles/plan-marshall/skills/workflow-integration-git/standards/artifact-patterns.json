{
  "_note": "Pre-commit artifact detection patterns. safe_patterns: always auto-delete. uncertain_patterns: require user confirmation. skip_dirs: skip entirely during traversal.",
  "safe_patterns": [
    "**/*.class",
    "**/*.pyc",
    "**/__pycache__/**",
    "**/*.egg-info/**",
    "**/.eggs/**",
    "**/*.tsbuildinfo",
    "**/*.temp",
    "**/*.backup*",
    "**/*.orig",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/*.swp",
    "**/*.swo",
    "**/*.log",
    ".plan/temp/**"
  ],
  "uncertain_patterns": [
    "target/**",
    "build/**",
    "dist/**",
    "out/**",
    ".next/**",
    ".turbo/**",
    ".parcel-cache/**",
    ".vite/**"
  ],
  "skip_dirs": [
    ".git",
    ".venv",
    "venv",
    "env",
    "node_modules"
  ]
}
