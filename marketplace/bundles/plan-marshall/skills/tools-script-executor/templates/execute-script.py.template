def _newest_cache_scripts_dir(skill: str) -> str | None:
    """Re-resolve ``{skill}/scripts`` against the newest surviving plugin-cache version dir.

    Fires only when a baked-in version-pinned bootstrap dir is absent (its embedded
    MARSHALL_VERSION cache path was GC-pruned). Walks
    ``~/.claude/plugins/cache/plan-marshall/*/skills/{skill}/scripts``, collecting every
    version dir that carries the skill, and returns the NEWEST by numeric version-tuple —
    the same newest-only selection the target-aware resolver uses. Pure stdlib and
    defensive: any failure (including a missing HOME) returns ``None`` rather than raising.
    """
    import re as _re

    def _vkey(name: str) -> tuple[int, ...]:
        return tuple(int(part) for part in _re.findall(r'\d+', name))

    try:
        cache_root = Path.home() / '.claude' / 'plugins' / 'cache' / 'plan-marshall'
        if not cache_root.is_dir():
            return None
        candidates = []
        for version_dir in cache_root.iterdir():
            if not version_dir.is_dir() or version_dir.name.startswith('.'):
                continue
            scripts_dir = version_dir / 'skills' / skill / 'scripts'
            if scripts_dir.is_dir():
                candidates.append((version_dir.name, scripts_dir))
        if candidates:
            _name, newest = max(candidates, key=lambda pair: _vkey(pair[0]))
            return str(newest.resolve())
    except (OSError, ValueError, RuntimeError):
        pass
    return None


def _bootstrap_sys_path_insert(skill: str, pinned_dir: str) -> None:
    """Insert ``pinned_dir`` on ``sys.path`` (fast path); self-heal to the newest cache dir when pruned.

    The version-pinned dir is used verbatim when it still exists on disk — the common,
    byte-stable case. When it is absent (GC-pruned), :func:`_newest_cache_scripts_dir`
    re-resolves the newest surviving cache version dir for ``skill`` and inserts that
    instead. Defensive: a missing pinned dir with no surviving cache dir inserts nothing.
    """
    if pinned_dir and Path(pinned_dir).is_dir():
        sys.path.insert(0, pinned_dir)
        return
    healed = _newest_cache_scripts_dir(skill)
    if healed:
        sys.path.insert(0, healed)


