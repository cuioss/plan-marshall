{
  "ci": {
    "provider": "github",
    "repo_url": "https://github.com/cuioss/plan-marshall.git",
    "detected_at": "2026-03-17T08:10:25Z",
    "commands": {
      "pr-create": "python3 .plan/execute-script.py tools-integration-ci:github pr create",
      "pr-reviews": "python3 .plan/execute-script.py tools-integration-ci:github pr reviews",
      "pr-comments": "python3 .plan/execute-script.py tools-integration-ci:github pr comments",
      "ci-status": "python3 .plan/execute-script.py tools-integration-ci:github ci status",
      "ci-wait": "python3 .plan/execute-script.py tools-integration-ci:github ci wait",
      "issue-create": "python3 .plan/execute-script.py tools-integration-ci:github issue create",
      "issue-view": "python3 .plan/execute-script.py tools-integration-ci:github issue view"
    }
  },
  "plan": {
    "phase-1-init": {
      "branch_strategy": "feature"
    },
    "phase-2-refine": {
      "confidence_threshold": 95,
      "compatibility": "breaking"
    },
    "phase-3-outline": {
      "plan_without_asking": true
    },
    "phase-4-plan": {
      "execute_without_asking": true
    },
    "phase-5-execute": {
      "commit_strategy": "per_plan",
      "finalize_without_asking": true,
      "verification_max_iterations": 5,
      "verification_1_quality_check": true,
      "verification_2_build_verify": true,
      "verification_domain_steps": {
        "documentation": {
          "1_doc_sync": "pm-documents:doc-verify"
        }
      }
    },
    "phase-6-finalize": {
      "max_iterations": 3,
      "1_commit_push": true,
      "2_create_pr": true,
      "3_automated_review": true,
      "4_sonar_roundtrip": true,
      "5_knowledge_capture": true,
      "6_lessons_capture": true
    }
  },
  "skill_domains": {
    "system": {
      "defaults": [
        "plan-marshall:dev-general-practices"
      ],
      "optionals": [
        "plan-marshall:dev-general-practices"
      ],
      "task_executors": {
        "documentation": "plan-marshall:task-documentation",
        "implementation": "plan-marshall:task-implementation",
        "module_testing": "plan-marshall:task-module_testing"
      },
      "project_skills": [
        "project:sync-plugin-cache",
        "project:verify-workflow",
        "project:recipe-plugin-compliance"
      ]
    },
    "build": {
      "bundle": "plan-marshall"
    },
    "general-dev": {
      "bundle": "plan-marshall"
    },
    "documentation": {
      "bundle": "pm-documents",
      "workflow_skill_extensions": {
        "triage": "pm-documents:ext-triage-docs"
      }
    },
    "plan-marshall-plugin-dev": {
      "bundle": "pm-plugin-development",
      "outline_skill": "pm-plugin-development:ext-outline-workflow",
      "workflow_skill_extensions": {
        "triage": "pm-plugin-development:ext-triage-plugin"
      }
    },
    "python": {
      "bundle": "pm-dev-python"
    },
    "active_profiles": [
      "implementation",
      "module_testing",
      "quality"
    ]
  },
  "system": {
    "retention": {
      "logs_days": 1,
      "archived_plans_days": 5,
      "memory_days": 5,
      "temp_on_maintenance": true
    }
  }
}